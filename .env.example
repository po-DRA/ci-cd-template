# ── Environment variable template ─────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# NEVER commit .env to git — it is already in .gitignore.
#
# How to get a TestPyPI token:
#   1. Create an account at https://test.pypi.org
#   2. Go to Account Settings → API tokens → "Add API token"
#   3. Scope: "Entire account" (or limit to this project after first upload)
#   4. Copy the token (starts with pypi-...)
#
# How to get a PyPI token (real registry):
#   Same steps at https://pypi.org

TEST_PYPI_API_TOKEN=pypi-your-test-pypi-token-here

# Only needed if you want to publish to the real PyPI:
# PYPI_API_TOKEN=pypi-your-real-pypi-token-here
